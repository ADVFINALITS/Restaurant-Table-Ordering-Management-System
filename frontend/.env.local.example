# URL of your Ruby (Rails) API, e.g. http://localhost:3000
# Leave it empty (or unreachable) and the app will automatically
# fall back to DEMO MODE, which runs entirely in the browser
# (localStorage + BroadcastChannel) so you can test the full flow
# before the Ruby backend exists.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Force demo mode on, even if NEXT_PUBLIC_API_BASE_URL is set.
NEXT_PUBLIC_DEMO_MODE=false

# Used to build the absolute QR code URLs in /admin/tables.
# In production this should be your real restaurant domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3001
